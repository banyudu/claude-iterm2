{
  "name": "claude-iterm2",
  "version": "0.2.3",
  "description": "iTerm2 visual status indicators and grid layouts for Claude Code",
  "author": "banyudu",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/banyudu/claude-iterm2.git"
  },
  "homepage": "https://banyudu.github.io/claude-iterm2/",
  "keywords": [
    "claude",
    "claude-code",
    "iterm2",
    "terminal",
    "status"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "hooks",
    "commands",
    "skills",
    ".claude-plugin",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0"
  },
  "scripts": {
    "build": "tsup && chmod +x dist/*.cjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup && chmod +x dist/*.cjs && tsc --noEmit"
  }
}
