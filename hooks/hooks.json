{
  "UserPromptSubmit": {
    "hooks": [{
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx ${CLAUDE_PLUGIN_ROOT}/src/hook.ts",
      "timeout": 5
    }]
  },
  "PreToolUse": {
    "hooks": [{
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx ${CLAUDE_PLUGIN_ROOT}/src/hook.ts",
      "timeout": 5
    }]
  },
  "PostToolUse": {
    "hooks": [{
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx ${CLAUDE_PLUGIN_ROOT}/src/hook.ts",
      "timeout": 5
    }]
  },
  "PostToolUseFailure": {
    "hooks": [{
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx ${CLAUDE_PLUGIN_ROOT}/src/hook.ts",
      "timeout": 5
    }]
  },
  "Stop": {
    "hooks": [{
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx ${CLAUDE_PLUGIN_ROOT}/src/hook.ts",
      "timeout": 5
    }]
  },
  "Notification": {
    "hooks": [{
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx ${CLAUDE_PLUGIN_ROOT}/src/hook.ts",
      "timeout": 5
